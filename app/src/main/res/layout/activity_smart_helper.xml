<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/smart_helper_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff">

    <!-- Header / TopAppBar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#ffffffff"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Helper"
                android:textColor="#0f172a"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="AI TUTOR ONLINE"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_box"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_smart_toy" />
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#e2e8f0"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Chat Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Welcome Message (AI) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_icon_box">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_auto_awesome" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Smart Helper"
                        android:textColor="#64748b"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_chat_bubble_left"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hello! I'm your AI math and science tutor. You can type your doubt or upload a photo of your homework. What are we studying today?"
                            android:textColor="#1e293b"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>
                
                <Space
                    android:layout_width="48dp"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- User Question 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="24dp">

                <Space
                    android:layout_width="48dp"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="You"
                        android:textColor="#64748b"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_chat_bubble_right"
                        android:padding="16dp"
                        android:elevation="0dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Can you help me solve this quadratic equation: x² - 5x + 6 = 0? I need to see the steps."
                            android:textColor="#ffffff"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_chat_bubble_left">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="#64748b" />
                </FrameLayout>
            </LinearLayout>

            <!-- AI Explanation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_icon_box">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_auto_awesome" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Smart Helper"
                        android:textColor="#64748b"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_chat_bubble_left"
                        android:padding="16dp"
                        android:orientation="vertical">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Of course! To solve x² - 5x + 6 = 0, we can use the factoring method."
                            android:textColor="#1e293b"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                            
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="12dp">
                            
                            <!-- Step 1 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="12dp">
                                
                                <TextView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:text="1"
                                    android:textColor="@color/primary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:background="@drawable/bg_circle_primary_light" />
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Find two numbers that multiply to 6 and add up to -5."
                                    android:textColor="#334155"
                                    android:textSize="14sp" />
                            </LinearLayout>
                            
                            <!-- Step 2 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="12dp">
                                
                                <TextView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:text="2"
                                    android:textColor="@color/primary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:background="@drawable/bg_circle_primary_light" />
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Those numbers are -2 and -3."
                                    android:textColor="#334155"
                                    android:textSize="14sp" />
                            </LinearLayout>
                            
                            <!-- Step 3 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="16dp">
                                
                                <TextView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:text="3"
                                    android:textColor="@color/primary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:background="@drawable/bg_circle_primary_light" />
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Rewrite the equation as: (x - 2)(x - 3) = 0"
                                    android:textColor="#334155"
                                    android:textSize="14sp"
                                    android:textStyle="italic" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Final Solution Block -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_final_solution"
                            android:padding="12dp"
                            android:layout_marginBottom="16dp">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FINAL SOLUTION:"
                                android:textColor="@color/primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textAllCaps="true" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="x = 2 or x = 3"
                                android:textColor="#0f172a"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="serif-monospace" />
                        </LinearLayout>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Would you like me to explain how to use the Quadratic Formula instead?"
                            android:textColor="#64748b"
                            android:textSize="12sp"
                            android:textStyle="italic" />

                    </LinearLayout>
                </LinearLayout>
                
                <Space
                    android:layout_width="48dp"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- User Doubt with Image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="24dp">

                <Space
                    android:layout_width="48dp"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="You"
                        android:textColor="#64748b"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- Image Attachment -->
                    <FrameLayout
                        android:layout_width="200dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_chat_bubble_left"> <!-- acts as rounded corner container -->
                        
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:color/darker_gray" />
                            
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#22000000" />
                            
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_zoom_in" />
                            
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chat_bubble_right"
                        android:padding="16dp"
                        android:elevation="0dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Can you help me with this diagram? I'm stuck on finding the tension force T."
                            android:textColor="#ffffff"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_chat_bubble_left">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="#64748b" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Input Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#ffffff"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#e2e8f0"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="-16dp" />

        <LinearLayout
            android:id="@+id/input_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_input"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_attachment"
                android:layout_marginStart="4dp" />

            <ImageButton
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add_a_photo" />

            <EditText
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Ask anything..."
                android:textColorHint="#94a3b8"
                android:textColor="#0f172a"
                android:textSize="14sp"
                android:paddingHorizontal="8dp"
                android:inputType="textMultiLine"
                android:maxLines="4" />

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_send_btn"
                android:layout_marginEnd="2dp">
                
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_send_arrow" />
            </FrameLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="AI can make mistakes. Verify important information with your textbooks."
            android:textColor="#94a3b8"
            android:textSize="10sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/input_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
