<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base border and background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#ffffff" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#e2e8f0" />
        </shape>
    </item>
    <!-- Left border overlay -->
    <item android:right="0dp" android:left="0dp" >
        <shape android:shape="rectangle">
            <solid android:color="@color/primary" />
            <corners android:topLeftRadius="8dp" android:bottomLeftRadius="8dp" />
        </shape>
    </item>
    <!-- Overlay white layer to mask everything except the left 4dp -->
    <item android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#ffffff" />
            <corners android:topRightRadius="8dp" android:bottomRightRadius="8dp" />
            <!-- Ensure top and bottom stroke are visible -->
            <stroke android:width="1dp" android:color="#e2e8f0" />
        </shape>
    </item>
</layer-list>
